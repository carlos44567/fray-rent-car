NODE_ENV=production
PORT=5001

# Database - Railway/Production
DB_HOST=your-prod-db-host.railway.app
DB_PORT=3306
DB_NAME=fray_rent_car_prod
DB_USER=frayrent_user
DB_PASS=your-secure-password-here-min-32-chars

# JWT Security
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-this
JWT_EXPIRES_IN=8h

# CORS - agregar dominio del admin también si es diferente
CORS_ORIGIN=https://fray-rent-car.com,https://admin.fray-rent-car.com

# Uploads
UPLOAD_DIR=uploads

